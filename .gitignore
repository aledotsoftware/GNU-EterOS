# éterOS - Git Ignore

# Los binarios de build SI se versionan para que Jules los pueda pushear
# y el usuario los descargue directamente.
# Solo ignoramos archivos temporales de compilación.

# Archivos objeto intermedios
*.o
*.elf
*.d

# Archivos temporales del sistema
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.code-workspace

# Logs temporales
build/serial_output.log
/build

# Verification artifacts
verification/*.png
__pycache__/
