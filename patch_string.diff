+char *strpbrk(const char *s, const char *accept) {
+    while (*s) {
+        if (strchr(accept, *s)) return (char *)s;
+        s++;
+    }
+    return NULL;
+}
+
+size_t strspn(const char *s, const char *accept) {
+    size_t count = 0;
+    while (*s && strchr(accept, *s)) {
+        count++;
+        s++;
+    }
+    return count;
+}
+
+size_t strcspn(const char *s, const char *reject) {
+    size_t count = 0;
+    while (*s) {
+        if (strchr(reject, *s)) {
+            break;
+        }
+        count++;
+        s++;
+    }
+    return count;
+}
