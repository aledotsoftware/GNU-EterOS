--- userspace/libc/include/arpa/inet.h
+++ userspace/libc/include/arpa/inet.h
@@ -3,5 +3,9 @@

 #include <netinet/in.h>

+in_addr_t inet_addr(const char *cp);
+int inet_aton(const char *cp, struct in_addr *inp);
+char *inet_ntoa(struct in_addr in);
+
 #endif /* _ARPA_INET_H */
--- userspace/libc/src/network.c
+++ userspace/libc/src/network.c
@@ -1,5 +1,8 @@
 #include <netinet/in.h>
 #include <stdint.h>
+#include <arpa/inet.h>
+#include <stdio.h>
+#include <string.h>

 /* Byte Order Functions */
 uint16_t htons(uint16_t v) {
@@ -17,3 +20,41 @@
 uint32_t ntohl(uint32_t v) {
     return htonl(v);
 }
+
+in_addr_t inet_addr(const char *cp) {
+    struct in_addr val;
+    if (inet_aton(cp, &val)) {
+        return val.s_addr;
+    }
+    return INADDR_NONE;
+}
+
+int inet_aton(const char *cp, struct in_addr *inp) {
+    uint32_t val = 0;
+    int base = 10;
+    uint32_t parts[4];
+    int pp = 0;
+
+    while (*cp) {
+        if (*cp >= '0' && *cp <= '9') {
+            val = (val * base) + (*cp - '0');
+        } else if (*cp == '.') {
+            if (pp >= 4) return 0;
+            parts[pp++] = val;
+            val = 0;
+        } else {
+            return 0;
+        }
+        cp++;
+    }
+    if (pp >= 4) return 0;
+    parts[pp++] = val;
+
+    uint32_t res = 0;
+    for (int i=0; i<pp; i++) {
+        res = (res << 8) | (parts[i] & 0xFF);
+    }
+    if (inp) inp->s_addr = htonl(res);
+    return 1;
+}
+
+char *inet_ntoa(struct in_addr in) {
+    static char buf[18];
+    uint8_t *bytes = (uint8_t *)&in.s_addr;
+    snprintf(buf, sizeof(buf), "%d.%d.%d.%d", bytes[0], bytes[1], bytes[2], bytes[3]);
+    return buf;
+}
